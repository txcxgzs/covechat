# Development: both processes bind only to loopback for a local reverse proxy.
COVECHAT_WEB_HOST=127.0.0.1
COVECHAT_WEB_PORT=5173
COVECHAT_API_HOST=127.0.0.1
COVECHAT_API_PORT=8080
COVECHAT_API_ORIGIN=http://127.0.0.1:8080

# One-click Docker deployment: the only host-visible port.
COVECHAT_HTTP_HOST=127.0.0.1
COVECHAT_HTTP_PORT=8088

# Replace before enabling persistence adapters.
POSTGRES_PASSWORD=replace-with-a-long-random-secret
MINIO_ROOT_USER=covechat
MINIO_ROOT_PASSWORD=replace-with-a-long-random-secret

# Required for public deployment. Comma-separated exact origins, no trailing slash.
ALLOWED_ORIGINS=https://chat.example.com

# Local API persistence (optional during `dev.ps1`, required in deployment).
DATABASE_URL=postgres://covechat:development-only@127.0.0.1:5432/covechat

# S3-compatible attachment storage (optional in local development).
S3_ENDPOINT=http://127.0.0.1:9000
S3_BUCKET=covechat-attachments
S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=covechat
AWS_SECRET_ACCESS_KEY=replace-with-a-long-random-secret
AWS_EC2_METADATA_DISABLED=true
